{
  "ProjectName": "SQLSentinel",
  "CentralSqlInstance": "localhost",
  "CentralDatabase": "SQLMonitoring",
  "DefaultConnectionTimeoutSeconds": 5,
  "DefaultQueryTimeoutSeconds": 15,
  "CollectorLogPath": "C:\\SQLSentinel\\Logs",
  "Collectors": {
    "PerformanceCounters": {
      "IsEnabled": true,
      "IntervalSeconds": 60,
      "QueryTimeoutSeconds": 15
    },
    "Connections": {
      "IsEnabled": true,
      "IntervalSeconds": 60,
      "QueryTimeoutSeconds": 10
    },
    "Blocking": {
      "IsEnabled": true,
      "IntervalSeconds": 60,
      "QueryTimeoutSeconds": 10
    },
    "WaitStats": {
      "IsEnabled": true,
      "IntervalSeconds": 300,
      "QueryTimeoutSeconds": 15
    },
    "DatabaseIO": {
      "IsEnabled": true,
      "IntervalSeconds": 300,
      "QueryTimeoutSeconds": 15
    },
    "ActiveRequests": {
      "IsEnabled": true,
      "IntervalSeconds": 60,
      "QueryTimeoutSeconds": 10,
      "MinElapsedTimeMs": 30000,
      "MinCpuTimeMs": 10000,
      "MinLogicalReads": 100000,
      "MinWaitTimeMs": 10000
    }
  }
}